#!/bin/sh

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT_DIR" || exit 0

JAVA_HOME_CANDIDATE="$(/usr/libexec/java_home -v 21 2>/dev/null)"

if [ -z "$JAVA_HOME_CANDIDATE" ]; then
  JAVA_HOME_CANDIDATE="$(/usr/libexec/java_home -v 17 2>/dev/null)"
fi

if [ -z "$JAVA_HOME_CANDIDATE" ]; then
  echo "❌ Se necesita Java 17 o superior para poder ejecutar Gradle."
  echo "Instala JDK 17 o 21 y inténtalo de nuevo."
  exit 1
fi

export JAVA_HOME="$JAVA_HOME_CANDIDATE"
export PATH="$JAVA_HOME/bin:$PATH"

echo "☕ Using Java:"
java -version

BRANCH_NAME="$(git rev-parse --abbrev-ref HEAD)"

if echo "$BRANCH_NAME" | grep -Eq '^(main|develop)$'; then
  echo "❌ No puedes hacer un commit en la rama '$BRANCH_NAME'."
  echo "Crea una rama feature/, bugfix/ o hotfix/ y haz el commit ahí."
  exit 1
fi

if echo "$BRANCH_NAME" | grep -Eq '^(feature|bugfix|hotfix)/'; then
  BRANCH_PATTERN='^(feature|bugfix|hotfix)/[A-Z][A-Z0-9_-]*-(X|[0-9]+)-[a-z0-9]+(-[a-z0-9]+)*$'

  if echo "$BRANCH_NAME" | grep -Eq "$BRANCH_PATTERN"; then
    echo "✅ Rama con el formato correcto: $BRANCH_NAME."
  else
    echo "❌ El nombre de la rama no es correcto: $BRANCH_NAME."
    echo
    echo "Debe seguir el siguiente formato:"
    echo "feature/PROJECT-123-add-login"
    echo "feature/PROJECT-123-change-repository-format"
    echo "bugfix/PROJECT-123-change-develop-endpoint"
    echo "bugfix/PROJECT-X-add-new-endpoint"
    echo
    exit 1
  fi
else
  echo "ℹ️ La rama '$BRANCH_NAME' no es feature/bugfix/hotfix, se omite la validación."
  echo
  exit 1
fi

echo "🔁 Running spotlessApply..."

if ./gradlew spotlessApply --no-configuration-cache; then
  echo "✅ spotlessApply OK"
  git add -u
  exit 0
else
  echo "❌ spotlessApply failed (check lint errors)"
  exit 1
fi
